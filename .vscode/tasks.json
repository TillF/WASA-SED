{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Make: build",
      "type": "shell",
      "command": "make",
      "args": [
        "DEBUG=1",
        "all"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
     {
      "label": "Run: meinprog (no debugger)",
      "type": "shell",
      "command": "${workspaceFolder}/build/bin/wasa_dbg",
      "args": [],
      "presentation": {"echo": true, "reveal": "always", "panel": "shared"},
      "dependsOn": ["Make: build"]
    }
  ]
}